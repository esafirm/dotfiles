{
  "ui": {
    "theme": "Dracula",
    "showMemoryUsage": true,
    "showModelInfoInChat": true
  },
  "general": {
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d"
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "output": {
    "format": "text"
  },
  "env": {
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": 1
  }
}
