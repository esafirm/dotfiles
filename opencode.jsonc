{
  "$schema": "https://opencode.ai/config.json",

  "instructions": [
    ".claude/CLAUDE.md"
  ],

  "skills": {
    "paths": [".claude/skills"]
  },

  "permission": {
    "edit": "allow",
    "bash": { "rm *": "deny", "*": "ask" },
    "external_directory": {
      "~/secrets/**": "deny",
      "~/secret_dir/**": "deny",
      "*": "allow"
    }
  }
}
