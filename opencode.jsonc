{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".claude/CLAUDE.md"
  ],
  "enabled_providers": ["opencode", "opencode-go"],
  "mcp": {
    "android-studio": {
      "type": "remote",
      "url": "http://127.0.0.1:64342/stream"
    },
    "firebase": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "firebase-tools@latest",
        "mcp",
        "--only",
        "crashlytics"
      ]
    }
  },
  "skills": {
    "paths": [".claude/skills"]
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "grep": "allow",
    "glob": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git diff-tree": "allow",
      "git diff-tree *": "allow",
      "cat *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "head *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "which *": "allow",
      "wc *": "allow",
      "rm *": "deny",
      "echo": "allow",
      "rtk git log *": "allow",
      "rtk git show *": "allow",
      "rtk git diff *": "allow",
      "rtk git diff-tree *": "allow",
      "rtk git status": "allow",
      "rtk git status *": "allow",
      "rtk git ls-tree *": "allow",
      "rtk cat *": "allow",
      "rtk ls": "allow",
      "rtk ls *": "allow",
      "sort *": "allow",
      "uniq *": "allow"
    },
    "android-studio_*": "allow",
    "android-studio_execute_terminal_command": "deny",
    "external_directory": {
      "~/secrets/**": "deny",
      "~/secret_dir/**": "deny",
      "*": "allow"
    }
  }
}
